{
    "name": "Demo Dev Container",
    "dockerFile": "Dockerfile",
    "workspaceFolder": "/workspace",
    "mounts": [
       {
         "source": "${localWorkspaceFolder}/src",
         "target": "/workspace",
         "type": "bind"
       }
    ],
    "remoteUser": "node",
    "shutdownAction": "stopContainer",
    "customizations": {
        "vscode": {
            "extensions": [
                "EditorConfig.EditorConfig"
            ]
        }
    },
    "forwardPorts": [
        3000,
        7007
    ]
}
{
    "containers": [
        {
            "name": "backstage_app1",
            "build": {
                "dir": ".",
                "file": "Dockerfile",
                "args": ["--build-arg", "START_COMMAND=start"],
                "tag_default": "latest"
            }
        },
        {
            "name": "backstage_app2",
            "build": {
                "dir": ".",
                "file": "Dockerfile",
                "args": ["--build-arg", "START_COMMAND=start-backend"],
                "tag_default": "latest"
            }
        }
    ],

    "container_apps": [
        {
            "name": "app1",
            "container_app_name": "@infra.container_app1_name",
            "environment_name": "@infra.container_app_environment",
            "app_type": "app",
            "container_name": "backstage_app1",
            "args_create": ["--ingress", "external", "--target-port", "3000"]
        },
        {
            "name": "app2",
            "container_app_name": "@infra.container_app2_name",
            "environment_name": "@infra.container_app_environment",
            "app_type": "app",
            "container_name": "backstage_app2",
            "args_create": ["--ingress", "external", "--target-port", "7007"]
        }
    ],

    "service_apps": [
        {
            "name": "app1",
            "service_app_name": "@infra.service_app1_name",
            "service_plan_name": "@infra.service_plan_name",
            "app_type": "container",
            "container_name": "backstage_app",
            "args_create": [],
            "app_settings": {
                "WEBSITES_PORT": "8000"
            }
        }
    ]
}

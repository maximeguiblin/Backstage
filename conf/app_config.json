{
    "containers": [
        {
            "name": "backstage_app_front",
            "build": {
                "dir": ".",
                "file": "Dockerfile",
                "args": [
                    "--build-arg",
                    "START_COMMAND=start",
                    "--build-arg",
                    "FRONT_ENDPOINT={@infra.front_endpoint}",
                    "--build-arg",
                    "CORS_ENDPOINT={@infra.cors_endpoint}",
                    "--build-arg",
                    "BACK_ENDPOINT={@infra.back_endpoint}"
                ],
                "tag_default": "latest"
            }
        },
        {
            "name": "backstage_app_back",
            "build": {
                "dir": ".",
                "file": "Dockerfile",
                "args": [
                    "--build-arg",
                    "START_COMMAND=start-backend",
                    "--build-arg",
                    "FRONT_ENDPOINT={@infra.front_endpoint}",
                    "--build-arg",
                    "CORS_ENDPOINT={@infra.cors_endpoint}",
                    "--build-arg",
                    "BACK_ENDPOINT={@infra.back_endpoint}"
                ],
                "tag_default": "latest"
            }
        }
    ],
    "container_apps": [
        {
            "name": "app_front",
            "container_app_name": "@infra.container_app_front_name",
            "environment_name": "@infra.container_app_environment",
            "app_type": "app",
            "container_name": "backstage_app_front",
            "args_create": [
                "--ingress",
                "external",
                "--target-port",
                "3000"
            ]
        },
        {
            "name": "app_back",
            "container_app_name": "@infra.container_app_back_name",
            "environment_name": "@infra.container_app_environment",
            "app_type": "app",
            "container_name": "backstage_app_back",
            "args_create": [
                "--ingress",
                "external",
                "--target-port",
                "7007"
            ],
            "env_vars": {
                "PG_HOST": "{#{@infra.keyvault_secrets.pg_host}}",
                "PG_PORT": "{#{@infra.keyvault_secrets.pg_port}}",
                "PG_USER": "{#{@infra.keyvault_secrets.pg_user}}",
                "PG_PASSWORD": "{#{@infra.keyvault_secrets.pg_password}}",
                "PG_DATABASE": "{#{@infra.keyvault_secrets.pg_database}}",
                "BACKSTAGE_CLIENT_ID": "{#{@infra.keyvault_secrets.backstage_client_id}}",
                "BACKSTAGE_CLIENT_SECRET": "{#{@infra.keyvault_secrets.backstage_client_secret}}",
                "BACKSTAGE_TENANT_ID": "{#{@infra.keyvault_secrets.backstage_tenant_id}}",
                "BACKSTAGE_ACCESS_TOKEN": "{#{@infra.keyvault_secrets.backstage_access_token}}",
                "BACKSTAGE_SONARQUBE_TOKEN": "{#{@infra.keyvault_secrets.backstage_sonarqube_token}}"
            }
        }
    ]
}
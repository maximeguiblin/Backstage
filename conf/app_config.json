{
    "containers": [
        {
            "name": "backstage_app_front",
            "build": {
                "dir": ".",
                "file": "Dockerfile",
                "args": [
                    "--build-arg",
                    "START_COMMAND=start",
                    "--build-arg",
                    "FRONT_ENDPOINT={@infra.front_endpoint}"
                ],
                "tag_default": "latest"
            }
        },
        {
            "name": "backstage_app_back",
            "build": {
                "dir": ".",
                "file": "Dockerfile",
                "args": [
                    "--build-arg",
                    "START_COMMAND=start-backend",
                    "--build-arg",
                    "BACK_ENDPOINT={@infra.back_endpoint}"
                ],
                "tag_default": "latest"
            }
        }
    ],
    "container_apps": [
        {
            "name": "app1",
            "container_app_name": "@infra.container_app1_name",
            "environment_name": "@infra.container_app_environment",
            "app_type": "app",
            "container_name": "backstage_app_front",
            "args_create": [
                "--ingress",
                "external",
                "--target-port",
                "3000"
            ]
        },
        {
            "name": "app2",
            "container_app_name": "@infra.container_app_back_name",
            "environment_name": "@infra.container_app_environment",
            "app_type": "app",
            "container_name": "backstage_app_back",
            "args_create": [
                "--ingress",
                "external",
                "--target-port",
                "7007"
            ],
            "env_vars": {
                "PG_HOST": "{#{@infra.keyvault_secrets.pg_host}}",
                "PG_PORT": "{#{@infra.keyvault_secrets.pg_port}}",
                "PG_USER": "{#{@infra.keyvault_secrets.pg_user}}",
                "PG_PASSWORD": "{#{@infra.keyvault_secrets.pg_password}}",
                "PG_DATABASE": "{#{@infra.keyvault_secrets.pg_database}}"
            }
        }
    ],
    "service_apps": [
        {
            "name": "app1",
            "service_app_name": "@infra.service_app_front_name",
            "service_plan_name": "@infra.service_plan_name",
            "app_type": "container",
            "container_name": "backstage_app",
            "args_create": [],
            "app_settings": {
                "WEBSITES_PORT": "8000"
            }
        }
    ]
}